{
  "_comment": "OpenClaw configuration template — replace ALL placeholder values before use",
  "agents": {
    "list": [
      {
        "id": "main",
        "workspace": "D:\\KI-CORE\\apps\\openclaw\\workspace",
        "model": {
          "primary": "ollama/jarvis",
          "fallbacks": [
            "ollama/qwen3:8b",
            "ollama/gemma3:12b",
            "anthropic/claude-sonnet-4-6"
          ]
        }
      },
      {
        "id": "nexus",
        "workspace": "D:\\KI-CORE\\apps\\openclaw\\workspace-nexus",
        "model": {
          "primary": "ollama-3060/nexus",
          "fallbacks": [
            "ollama/qwen2.5-coder:7b"
          ]
        }
      },
      {
        "id": "clio",
        "workspace": "D:\\KI-CORE\\apps\\openclaw\\workspace-clio",
        "model": {
          "primary": "claude-cli/claude-opus-4-7"
        }
      }
    ],
    "defaults": {
      "workspace": "D:\\KI-CORE\\apps\\openclaw\\workspace",
      "timeoutSeconds": 600,
      "compaction": {
        "reserveTokensFloor": 1000,
        "reserveTokens": 1000
      },
      "model": {
        "primary": "ollama/jarvis",
        "fallbacks": [
          "ollama/gemma3:12b",
          "ollama/qwen3:8b",
          "anthropic/claude-sonnet-4-6"
        ]
      },
      "cliBackends": {
        "claude-cli": {
          "command": "C:\\Users\\<USERNAME>\\.local\\bin\\claude.exe"
        }
      }
    }
  },
  "gateway": {
    "port": 18789,
    "bind": "0.0.0.0",
    "auth": {
      "password": "<REPLACE_WITH_STRONG_PASSWORD>"
    },
    "allowedOrigins": [
      "192.168.0.0/24"
    ]
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://127.0.0.1:11434",
        "api": "ollama",
        "apiKey": "OLLAMA_API_KEY",
        "models": [
          {
            "id": "jarvis",
            "name": "Jarvis (qwen3:14b)",
            "contextWindow": 65536,
            "maxTokens": 8192,
            "input": ["text"],
            "cost": { "input": 0, "output": 0 }
          },
          {
            "id": "qwen3:8b",
            "name": "qwen3:8b",
            "contextWindow": 32768,
            "maxTokens": 8192,
            "input": ["text"],
            "cost": { "input": 0, "output": 0 }
          },
