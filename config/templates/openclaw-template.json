            "id": "qwen3:14b",
            "name": "qwen3:14b",
            "contextWindow": 65536,
            "maxTokens": 8192,
            "input": ["text"],
            "cost": { "input": 0, "output": 0 }
          },
          {
            "id": "gemma3:12b",
            "name": "gemma3:12b",
            "contextWindow": 32768,
            "maxTokens": 8192,
            "input": ["text"],
            "cost": { "input": 0, "output": 0 }
